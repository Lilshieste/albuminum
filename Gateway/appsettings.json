{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "dotnet-route": {
        "ClusterId": "dotnet-cluster",
        "Match": { "Path": "/dotnet/api/{**catch-all}" },
        "Transforms": [
          { "PathRemovePrefix": "/dotnet" }
        ]
      },
      "node-route": {
        "ClusterId": "node-cluster",
        "Match": { "Path": "/node/api/{**catch-all}" },
        "Transforms": [
          { "PathRemovePrefix": "/node" }
        ]
      },
      "default-api-route": {
        "ClusterId": "dotnet-cluster",
        "Match": { "Path": "/api/{**catch-all}" }
      }
    },
    "Clusters": {
      "dotnet-cluster": {
        "Destinations": { "d1": { "Address": "http://dotnet-api" } }
      },
      "node-cluster": { "Destinations": { "d1": { "Address": "http://node-api" } } }
    }
  }
}
